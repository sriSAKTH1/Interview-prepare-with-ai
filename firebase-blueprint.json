{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "careerPath": { "type": "string" },
        "totalStudyMinutes": { "type": "number" },
        "journeyData": {
          "type": "object",
          "properties": {
            "language": { "type": "string" },
            "skillLevel": { "type": "number" },
            "langRating": { "type": "number" },
            "dsaRating": { "type": "number" },
            "completedAt": { "type": "string", "format": "date-time" }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "CompletedTopic": {
      "title": "Completed Topic",
      "description": "A topic that the user has marked as completed",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "topicId": { "type": "string" },
        "topicName": { "type": "string" },
        "category": { "type": "string" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "topicId", "topicName", "completedAt"]
    },
    "TestResult": {
      "title": "Test Result",
      "description": "Result of a completed assessment",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "score": { "type": "string" },
        "total": { "type": "number" },
        "correct": { "type": "number" },
        "time": { "type": "string" },
        "status": { "type": "string" },
        "feedback": { "type": "string" },
        "weaknesses": { "type": "array", "items": { "type": "string" } },
        "improvements": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "title", "score", "createdAt"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback and bug reports",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "type": { "type": "string", "enum": ["General Feedback", "Bug Report", "Feature Request", "Other"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["new", "reviewed", "resolved"] }
      },
      "required": ["uid", "type", "content", "createdAt"]
    },
    "Note": {
      "title": "Note",
      "description": "User's personal note",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "updatedAt": { "type": "number" },
        "isPinned": { "type": "boolean" }
      },
      "required": ["uid", "title", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/completedTopics/{id}": {
      "schema": "CompletedTopic",
      "description": "Topics completed by users"
    },
    "/testResults/{id}": {
      "schema": "TestResult",
      "description": "Assessment results"
    },
    "/feedback/{id}": {
      "schema": "Feedback",
      "description": "User feedback"
    },
    "/notes/{id}": {
      "schema": "Note",
      "description": "User's personal notes"
    }
  }
}
